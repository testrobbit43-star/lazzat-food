# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production-at-least-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,*.railway.app,*.vercel.app

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=lazzat_db
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# Or use DATABASE_URL for Railway
DATABASE_URL=postgresql://user:password@localhost:5432/lazzat_db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://lazzat-food.vercel.app

# Telegram Bot
TELEGRAM_BOT_TOKEN=8896986265:AAHfmDiIrXTnjqa0sxSAh3fA-4iUI2bjb3k
TELEGRAM_CHAT_ID=8191123267

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Redis (optional, for Celery)
REDIS_URL=redis://localhost:6379/0

# AWS S3 (optional, for media storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Environment
ENVIRONMENT=development
